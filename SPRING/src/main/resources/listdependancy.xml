<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">
    <bean id="L1" class="dependancy_injection.Library1">
        <property name="id" value="101"></property>
        <property name="name" value="Friends"></property>
        <property name="books">
                    <list>
                        <ref bean="B1"></ref>
                        <ref bean="B2"></ref>
                        <ref bean="B3"></ref>
                    </list>
        </property>
    </bean>
    <bean id="B1" class="dependancy_injection.Book">
        <property name="bookid" value="1"></property>
        <property name="bookname" value="Martian"></property>
    </bean>
    <bean id="B2" class="dependancy_injection.Book">
        <property name="bookid" value="2"></property>
        <property name="bookname" value="IronFist"></property>
    </bean>
    <bean id="B3" class="dependancy_injection.Book">
        <property name="bookid" value="3"></property>
        <property name="bookname" value="Oddysey"></property>
    </bean>
</beans>